# ── LLM 模型配置 ─────────────────────────────────────────────
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

# ── 阿里云 DashScope ASR 模型 ───────────────────────────────
DASHSCOPE_API_KEY=your_api_key_here
ASR_API_KEY=your_api_key_here
ASR_MODEL=fun-asr-realtime

# ── 阿里云 Qwen TTS 模型 ──────────────────────────────────
QWEN_TTS_API_KEY=your_api_key_here
QWEN_TTS_MODEL=cosyvoice-v3.5-flash

# 复刻音色 ID（在阿里云百炼控制台创建）
# VOICE_ID1=cosyvoice-v3.5-flash-bailian-c8b555002f404397863708adffdb6b12 # 洛琪希
# VOICE_ID2=cosyvoice-v3.5-flash-bailian-e2469654e48c44b7b5cdd9b05139e10d # 菲比

# ── API 密钥通用回退 ──────────────────────────────────────
IMAGE_API_KEY=your_api_key_here